<odoo>
    <record id="view_nosheet_ir_ui_menu_form" model="ir.ui.view">
        <field name="name">nosheet.ir.ui.menu.form</field>
        <field name="model">ir.ui.menu</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <form string="Menu">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_id" groups="base.group_no_one"/>
                            <field name="sequence" groups="base.group_no_one"/>
                            <field name="group_ids" string="Visibility" widget="many2many_tags"/>
                        </group>
                        <group groups="base.group_no_one">
                            <field name="complete_name"/>
                            <field name="action"/>
                            <field name="web_icon"/>
                            <field name="web_icon_data"/>
                            <field name="is_custom"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Submenus" name="submenus" groups="base.group_no_one">
                            <!-- Note: make sure you have 'ir.ui.menu.full_list'
                                in the context to see all submenus! -->
                            <field name="child_id" context="{'default_parent_id': id, 'default_is_custom': True}">
                                <list string="Menu">
                                    <field name="sequence"/>
                                    <field icon="icon" name="name" string="Menu"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_module_filter_inherit_menu" model="ir.ui.view">
        <field name="name">view.module.filter.inherit.menu</field>
        <field name="model">ir.ui.menu</field>
        <field name="inherit_id" ref="base.edit_menu_access_search"/>
        <field name="arch" type="xml">

            <xpath expr="//search" position="inside">
            <filter name="is_custom_menu"
                string="Is custom?"
                domain="[('is_custom', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <record id="base.grant_menu_access" model="ir.actions.act_window">
        <field name="context">
            {'ir.ui.menu.full_list':True, 'search_default_is_custom_menu': True, 'default_is_custom': True}        
        </field>
    </record>

</odoo>
