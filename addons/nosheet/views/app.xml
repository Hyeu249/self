<odoo>
    <record id="view_custom_app_list" model="ir.ui.view">
        <field name="name">nosheet.custom.app.list</field>
        <field name="model">nosheet.custom.app</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_custom_app_form" model="ir.ui.view">
        <field name="name">nosheet.custom.app.form</field>
        <field name="model">nosheet.custom.app</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                        </group>

                        <group>
                            <field name="uuid"/>
                            <field name="menu_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Models">
                            <field name="model_ids">
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_custom_app_search" model="ir.ui.view">
        <field name="name">nosheet.custom.app.search</field>
        <field name="model">nosheet.custom.app</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="uuid"/>
                <field name="menu_id"/>
            </search>
        </field>
    </record>

    <record id="action_custom_app" model="ir.actions.act_window">
        <field name="name">Studio</field>
        <field name="res_model">nosheet.custom.app</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create_views_menu_access': True}</field>
    </record>

    <menuitem id="menu_custom_app"
              name="Studio"
              action="action_custom_app"
              groups="base.group_no_one"
              sequence="1000"/>

    <record id="nosheet_custom_app_update_module" model="ir.actions.server">
        <field name="name">Update Module</field>
        <field name="model_id" ref="nosheet.model_nosheet_custom_app"/>
        <field name="binding_model_id" ref="nosheet.model_nosheet_custom_app" />
        <field name="state">code</field>
        <field name="code">
            for r in records:
                r.update_module()
        </field>
    </record>

</odoo>
